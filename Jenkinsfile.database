pipeline {
    agent { label 'electronix' }
    stages {
        stage('Creating Database') {
        steps{
            sh 'python3 scripts/create_db.py'
        }

    }

        stage('Smoke Test') {
            steps{
            sh 'python3 scripts/smoke_test.py'
            }
        }
    }

    postv{
        success {
            echo 'Database Creation Successfull'


        }
        failure {
            echo 'Database Failed'
        }
    }


}
